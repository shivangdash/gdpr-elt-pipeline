POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gdpr
POSTGRES_USER=gdpr_user
POSTGRES_PASSWORD=gdpr_password
DATABASE_URL=******postgres:5432/gdpr
# Replace with a cryptographically secure random value in production.
PII_HASH_SALT=replace-with-random-salt
MASKING_ENVIRONMENT=staging
PIPELINE_DATA_DIR=/tmp/gdpr_pipeline_data
LINEAGE_LOG_PATH=/opt/pipeline/logs/lineage.jsonl
AUDIT_LOG_PATH=/opt/pipeline/logs/audit.jsonl
RETENTION_DAYS_TRANSACTIONS=365
